{
  "name": "chantier-compagnon",
  "private": true,
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "bootstrap": "pnpm install",
    "dev": "pnpm --parallel --filter @chantier-compagnon/api --filter @chantier-compagnon/web dev",
    "dev:api": "pnpm --filter @chantier-compagnon/api dev",
    "dev:web": "pnpm --filter @chantier-compagnon/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  }
}
